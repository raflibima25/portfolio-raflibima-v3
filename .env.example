# ============================================================
# NODEMAILER (Untuk mengirim email dari contact form)
# ============================================================
NODEMAILER_PW=your_email_password
NODEMAILER_EMAIL=your_email@example.com

# ============================================================
# GITHUB TOKEN (Untuk menampilkan GitHub stats)
# ============================================================
GITHUB_READ_USER_TOKEN_PERSONAL=your_github_personal_access_token

# GITLAB TOKEN (Untuk GitLab stats)
# Tambahkan 2 Personal Access Token (sebagai member/user dari kedua akun) agar bisa membaca kontribusi private di Dashboard
GITLAB_READ_USER_TOKEN_PERSONAL_RAFLIBIMA1106=your_gitlab_personal_access_token_1
GITLAB_READ_USER_TOKEN_PERSONAL_SANGKURIANG=your_gitlab_personal_access_token_2

# ============================================================
# UMAMI ANALYTICS (Opsional, untuk tracking pengunjung)
# ============================================================
UMAMI_API_KEY=your_umami_api_key
UMAMI_WEBSITE_ID_SITE=your_umami_site_id
UMAMI_WEBSITE_ID_MYID=your_umami_myid_id

# ============================================================
# WAKATIME STATS
# ============================================================
WAKATIME_API_ID=your_wakatime_api_id
WAKATIME_API_KEY=your_wakatime_api_key

# ============================================================
# MONKEYTYPE & CODEWARS STATS
# ============================================================
MONKEYTYPE_API_KEY=your_monkeytype_api_key
CODEWARS_USER_ID=your_codewars_username

# ============================================================
# SUPABASE (PostgreSQL Database)
# Dapatkan dari: https://supabase.com/dashboard/project/_/settings/database
# ============================================================
POSTGRES_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
POSTGRES_PRISMA_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
POSTGRES_URL_NO_SSL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=disable
POSTGRES_URL_NON_POOLING=aws-0-[REGION].pooler.supabase.com
POSTGRES_USER=postgres
POSTGRES_HOST=db.[YOUR-PROJECT-REF].supabase.co
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=postgres
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# AUTHENTICATION (Google & GitHub OAuth + NextAuth)
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/developers
# NextAuth Secret: jalankan `openssl rand -base64 32`
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_ID=your_github_app_client_id
GITHUB_SECRET=your_github_app_client_secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# ============================================================
# GEMINI AI (Opsional)
# Dapatkan dari: https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=your_gemini_api_key

# ============================================================
# FIREBASE (Firestore, Auth, dll)
# Dapatkan dari: https://console.firebase.google.com/project/_/settings/general
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_DB_URL=https://your_project_id-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_CHAT_DB=messages

# ============================================================
# PENGATURAN LAINNYA
# ============================================================
NEXT_PUBLIC_AUTHOR_EMAIL=your_email@example.com
DOMAIN=http://localhost:3000
